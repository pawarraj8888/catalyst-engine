# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# Virtual envs
.venv/
venv/
env/
.env

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Data — never commit raw or interim. Processed warehouse IS tracked via LFS.
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/processed/catalyst.duckdb
!data/external/.gitkeep

# DuckDB warehouse
*.duckdb
*.duckdb.wal

# Reports — generated outputs
reports/onepagers/*.html
reports/onepagers/*.pdf
reports/figures/*.png
!reports/figures/.gitkeep

# Logs
logs/
*.log

# Secrets
.env.local
*.pem
*.key

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# OS
Thumbs.db
