# Copy to .env and fill in. Never commit .env.

# --- Data sources ---
# Finnhub: https://finnhub.io/register (free tier: 60 calls/min)
FINNHUB_API_KEY=

# Tradier sandbox: https://developer.tradier.com/ (free, real-time-ish options)
TRADIER_API_KEY=
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# SEC EDGAR requires a User-Agent header identifying you.
# Format: "Your Name your@email.com"
SEC_USER_AGENT=Raj Pawar raj@example.com

# --- Storage ---
DUCKDB_PATH=data/processed/catalyst.duckdb

# --- Runtime ---
LOG_LEVEL=INFO
ENVIRONMENT=local

# --- Alerts (optional, for intraday 8-K alerter, Phase 4) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
